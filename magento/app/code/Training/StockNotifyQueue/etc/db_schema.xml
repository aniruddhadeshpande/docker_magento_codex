<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="training_erp_stock_event" resource="default" engine="innodb" comment="Training ERP Stock Event">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="event_id" nullable="false" length="100" comment="ERP Event ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" length="64" comment="Product SKU"/>
        <column xsi:type="int" name="qty_delta" nullable="false" comment="Quantity Delta"/>
        <column xsi:type="varchar" name="source_code" nullable="false" length="32" default="default"
                comment="Inventory Source Code"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="received"
                comment="Processing Status"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Error Message"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="processed_at" on_update="false" nullable="true"
                comment="Processed At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="TRAINING_ERP_STOCK_EVENT_EVENT_ID">
            <column name="event_id"/>
        </constraint>
        <index referenceId="TRAINING_ERP_STOCK_EVENT_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="TRAINING_ERP_STOCK_EVENT_SKU" indexType="btree">
            <column name="sku"/>
        </index>
    </table>
</schema>
